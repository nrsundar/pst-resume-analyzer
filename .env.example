# ---------------------------------------------------------------
# Option A: Direct API key
# Get your key at: https://console.anthropic.com/api-keys
# Set provider: "anthropic" in config.yaml
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------------------------------------------------------------
# Option B: AWS Bedrock
# Set provider: "bedrock" in config.yaml
# Use ONE of the following credential methods:
#
# Method 1 — Static credentials (copy from AWS Console > Security credentials)
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Method 2 — Temporary credentials (e.g. from AWS SSO / assumed role)
# AWS_SESSION_TOKEN=your-session-token

# Method 3 — If running on EC2 / ECS with an IAM role attached,
# no credentials are needed here — boto3 picks them up automatically.
